rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Catch-all Block (must be explicitly declared first)
    match /{document=**} {
      allow read, write: if false;
    }

    // Explicit Rules for App Collections
    
    // 1. Users Collection
    match /users/{userId} {
      allow read, write: if true;
    }

    // 2. Items Listings Collection
    match /items/{itemId} {
      allow read, write: if true;
    }

    // 3. Swipes Cards Collection
    match /swipes/{swipeId} {
      allow read, write: if true;
    }

    // 4. Matches Collection
    match /matches/{matchId} {
      allow read, write: if true;
    }

    // 5. Realtime Messages Collection
    match /messages/{messageId} {
      allow read, write: if true;
    }
  }
}
